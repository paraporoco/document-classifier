# Document Sensitivity Classifier — Web Server
#
# Build:
#   (from project root, after running convert_artefacts.py)
#   docker build -t doc-classifier-web ./classifier_web
#
# Run:
#   docker run -p 8000:8000 doc-classifier-web
#
# With server-side classify enabled:
#   docker run -p 8000:8000 -e ENABLE_SERVER_CLASSIFY=true doc-classifier-web

FROM python:3.12-slim

WORKDIR /app

# Install dependencies first (layer-cached unless requirements change)
COPY requirements-web.txt .
RUN pip install --no-cache-dir -r requirements-web.txt

# Copy server
COPY server.py .

# Copy web application (SPA static files)
COPY web/ ./web/

# Copy browser-compatible model artefacts
# These are generated by running: python classifier_production/convert_artefacts.py
# Run that script on the host before building this image.
COPY web_artefacts/ ./web_artefacts/

EXPOSE 8000

CMD ["uvicorn", "server:app", "--host", "0.0.0.0", "--port", "8000"]
